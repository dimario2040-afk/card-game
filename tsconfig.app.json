{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Typing */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/ui/animations",
    "src/ui/audio",
    "src/ui/components/Board.tsx",
    "src/ui/components/CardBack.tsx",
    "src/ui/components/CardHand.tsx",
    "src/ui/components/index.ts",
    "src/ui/screens/HeroSelect.tsx",
    "src/data/heroes.ts",
    "src/game/game-loop.ts",
    "src/game/game-loop.test.ts"
  ]
}
